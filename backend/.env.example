PORT=4000
# Base de datos MySQL (elige una opción)
# Opción DSN:
# DATABASE_URL=mysql://root:TU_PASSWORD@127.0.0.1:3306/jj-indum
# Opción variables separadas:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=TU_PASSWORD
# MYSQL_DATABASE=jj-indum

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# Mercado Pago
# Access token del vendedor (test o producción)
MP_ACCESS_TOKEN=INSERTAR_ACCESS_TOKEN

# Correo Argentino (si se integra API real)
# CA_API_KEY=INSERTAR_API_KEY
# CA_API_URL=https://api.correoargentino.example