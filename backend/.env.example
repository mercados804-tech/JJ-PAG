PORT=4000
NODE_ENV=development
# Base de datos MySQL (elige una opción)
# Opción DSN:
# DATABASE_URL=mysql://root:TU_PASSWORD@127.0.0.1:3306/jj-indum
# Opción variables separadas:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=TU_PASSWORD
# MYSQL_DATABASE=jj-indum

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:5175
BACKEND_URL=http://localhost:4000

# SMTP (Gmail por ejemplo)
# SMTP_USER=tuemail@gmail.com
# SMTP_PASS=TU_APP_PASSWORD
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM="JJ Indumentaria <tuemail@gmail.com>"

# Resend (opcional, por API)
# RESEND_API_KEY=re_...
# RESEND_FROM="JJ Indumentaria <no-reply@tudominio.com>"

# WhatsApp (opcional: número a donde se abre el chat si no hay teléfono del usuario)
# WHATSAPP_SUPPORT_NUMBER=54911XXXXXXXX

# Mercado Pago
# Access token del vendedor (test o producción)
MP_ACCESS_TOKEN=INSERTAR_ACCESS_TOKEN

# Correo Argentino (si se integra API real)
# CA_API_KEY=INSERTAR_API_KEY
# CA_API_URL=https://api.correoargentino.example
